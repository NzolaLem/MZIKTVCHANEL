# Copy this file to ".env" and fill in real values. ".env" is gitignored.

# Admin dashboard password and the secret used to sign tickets/sessions.
ADMIN_PASSWORD=replace-with-a-strong-admin-password
TOKEN_SECRET=replace-with-a-long-random-token-secret
API_PORT=8787

# Supabase — from the Supabase dashboard:
#   Project Settings → Data API  → Project URL
#   Project Settings → API Keys  → Secret key or legacy service_role key (never expose to the browser)
SUPABASE_PROJECT_ID=lzepyzvisjkwnytxopmd
SUPABASE_URL=https://lzepyzvisjkwnytxopmd.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-with-your-server-only-key
# SUPABASE_SECRET_KEY=replace-with-your-sb_secret-key
